PORT=3000

# Firebase Admin SDK (server-side)
# Create a service account in Firebase Console:
# Project settings -> Service accounts -> Generate new private key
# Easiest option on Windows: point to the downloaded JSON file.
# FIREBASE_SERVICE_ACCOUNT_PATH=C:\\path\\to\\serviceAccountKey.json
FIREBASE_PROJECT_ID=pixo-mind
FIREBASE_CLIENT_EMAIL=your-service-account@pixo-mind.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_WITH_YOUR_KEY\n-----END PRIVATE KEY-----\n"

# Optional: only needed if you plan to use Firebase Storage from the backend
FIREBASE_STORAGE_BUCKET=pixo-mind.firebasestorage.app

